    @Override
    @Transactional(rollbackFor = Exception.class)
    public boolean createRole(RoleCreateDTO createDTO) {
        // 检查角色编码唯一性
        if (!checkRoleCodeUnique(createDTO.getRoleCode(), null)) {
            throw new RuntimeException("角色编码已存在");
        }

        // 检查角色名称唯一性
        if (!checkRoleNameUnique(createDTO.getRoleName(), null)) {
            throw new RuntimeException("角色名称已存在");
        }

        // 创建角色实体
        SysRole role = new SysRole();
        BeanUtil.copyProperties(createDTO, role);
        
        // 设置默认值
        role.setStatus(createDTO.getStatus() != null ? createDTO.getStatus() : 1);
        role.setRoleType(createDTO.getRoleType() != null ? createDTO.getRoleType() : 1);
        role.setRoleLevel(createDTO.getRoleLevel() != null ? createDTO.getRoleLevel() : 4);
        role.setDataScope(createDTO.getDataScope() != null ? createDTO.getDataScope() : 5);
        role.setSort(createDTO.getSort() != null ? createDTO.getSort() : 0);
        role.setIsSystem(0);
        role.setIsDeletable(1);
        role.setIsEditable(1);

        // 保存角色
        boolean success = save(role);
        if (success) {
            // 分配菜单权限
            if (createDTO.getMenuIds() != null && !createDTO.getMenuIds().isEmpty()) {
                assignRoleMenus(role.getId(), createDTO.getMenuIds());
            }
            
            // 分配数据权限
            if (createDTO.getDeptIds() != null && !createDTO.getDeptIds().isEmpty()) {
                assignRoleDepts(role.getId(), createDTO.getDeptIds());
            }
        }
        
        return success;
    }

    @Override
    @Transactional(rollbackFor = Exception.class)
    public boolean updateRole(RoleUpdateDTO updateDTO) {
        // 检查角色是否存在
        SysRole existingRole = getById(updateDTO.getId());
        if (existingRole == null) {
            throw new RuntimeException("角色不存在");
        }

        // 检查是否为系统内置角色
        if (existingRole.getIsSystem() == 1) {
            throw new RuntimeException("系统内置角色不能修改");
        }

        // 检查角色编码唯一性
        if (!checkRoleCodeUnique(updateDTO.getRoleCode(), updateDTO.getId())) {
            throw new RuntimeException("角色编码已存在");
        }

        // 检查角色名称唯一性
        if (!checkRoleNameUnique(updateDTO.getRoleName(), updateDTO.getId())) {
            throw new RuntimeException("角色名称已存在");
        }

        // 更新角色信息
        SysRole role = new SysRole();
        BeanUtil.copyProperties(updateDTO, role);
        role.setUpdateTime(LocalDateTime.now());

        // 更新角色
        boolean success = updateById(role);
        if (success) {
            // 重新分配菜单权限
            if (updateDTO.getMenuIds() != null) {
                assignRoleMenus(updateDTO.getId(), updateDTO.getMenuIds());
            }
            
            // 重新分配数据权限
            if (updateDTO.getDeptIds() != null) {
                assignRoleDepts(updateDTO.getId(), updateDTO.getDeptIds());
            }
        }
        
        return success;
    }

    @Override
    @Transactional(rollbackFor = Exception.class)
    public boolean deleteRole(Long id) {
        if (id == null) {
            return false;
        }
        
        // 检查角色是否存在
        SysRole role = getById(id);
        if (role == null) {
            return false;
        }
        
        // 检查是否为系统内置角色
        if (role.getIsSystem() == 1) {
            throw new RuntimeException("系统内置角色不能删除");
        }
        
        // 检查是否有关联用户
        List<SysRole> userRoles = getRolesByUserId(id);
        if (userRoles != null && !userRoles.isEmpty()) {
            throw new RuntimeException("角色下存在用户，不能删除");
        }
        
        return removeById(id);
    }

    @Override
    @Transactional(rollbackFor = Exception.class)
    public boolean batchDeleteRoles(List<Long> ids) {
        if (ids == null || ids.isEmpty()) {
            return false;
        }
        
        // 检查是否包含系统内置角色
        List<SysRole> roles = listByIds(ids);
        for (SysRole role : roles) {
            if (role.getIsSystem() == 1) {
                throw new RuntimeException("系统内置角色不能删除");
            }
        }
        
        return removeByIds(ids);
    }

    @Override
    public boolean updateRoleStatus(Long id, Integer status) {
        if (id == null || status == null) {
            return false;
        }
        
        // 检查是否为系统内置角色
        SysRole role = getById(id);
        if (role != null && role.getIsSystem() == 1) {
            throw new RuntimeException("系统内置角色状态不能修改");
        }
        
        return baseMapper.updateRoleStatus(id, status) > 0;
    }

    @Override
    public boolean updateRoleSort(Long id, Integer sort) {
        if (id == null || sort == null) {
            return false;
        }
        
        return baseMapper.updateRoleSort(id, sort) > 0;
    }

