    @Override
    @Transactional(rollbackFor = Exception.class)
    public boolean copyRole(Long sourceRoleId, String newRoleName, String newRoleCode) {
        if (sourceRoleId == null || StrUtil.isBlank(newRoleName) || StrUtil.isBlank(newRoleCode)) {
            return false;
        }
        
        // 检查新角色名称和编码是否唯一
        if (!checkRoleNameUnique(newRoleName, null)) {
            throw new RuntimeException("角色名称已存在");
        }
        if (!checkRoleCodeUnique(newRoleCode, null)) {
            throw new RuntimeException("角色编码已存在");
        }
        
        // 获取源角色信息
        SysRole sourceRole = getById(sourceRoleId);
        if (sourceRole == null) {
            throw new RuntimeException("源角色不存在");
        }
        
        // 创建新角色
        SysRole newRole = new SysRole();
        BeanUtil.copyProperties(sourceRole, newRole);
        newRole.setId(null);
        newRole.setRoleName(newRoleName);
        newRole.setRoleCode(newRoleCode);
        newRole.setRoleDesc("复制自：" + sourceRole.getRoleName());
        newRole.setIsSystem(0);
        newRole.setIsDeletable(1);
        newRole.setIsEditable(1);
        newRole.setCreateTime(LocalDateTime.now());
        newRole.setUpdateTime(LocalDateTime.now());
        
        // 保存新角色
        boolean success = save(newRole);
        if (success) {
            // 复制菜单权限
            List<Long> menuIds = getRoleMenuIds(sourceRoleId);
            if (menuIds != null && !menuIds.isEmpty()) {
                assignRoleMenus(newRole.getId(), menuIds);
            }
            
            // 复制数据权限
            List<Long> deptIds = getRoleDeptIds(sourceRoleId);
            if (deptIds != null && !deptIds.isEmpty()) {
                assignRoleDepts(newRole.getId(), deptIds);
            }
        }
        
        return success;
    }
}